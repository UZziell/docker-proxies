listen: :443 

tls:
  cert: /etc/hysteria/certs/live/CHANGEME_TO_CERTBOT_CERTIFICATE_DOMAIN/fullchain.pem
  key: /etc/hysteria/certs/live/CHANGEME_TO_CERTBOT_CERTIFICATE_DOMAIN/privkey.pem
  sniGuard: strict

auth:
  type: password
  password: CHANGEME_TO_USER_PASSWORD
  userpass:
    user1: pass1
    user2: pass2
    user3: pass3

masquerade:
  type: proxy
  proxy:
    # CHANGEME_TO_MASQUERADE_URL
    url: https://archive.ubuntu.com/ubuntu
    rewriteHost: true
  listenHTTP: :80
  listenHTTPS: :443
  forceHTTPS: true

disableUDP: false

obfs:
  type: salamander
  salamander:
    password: CHANGEME_TO_OBFS_PASSWORD

