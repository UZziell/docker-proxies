                    "162.252.212.0/24",
                    "162.252.215.0/24",
                    "172.98.36.0/24",
                    "199.38.148.0/24",
                    "199.84.138.0/24",
                    "206.166.193.0/24",
                    "208.95.115.0/24",
                    "216.59.58.0/24",
                    "216.59.61.0/24",
                    "216.59.62.0/24",
                    "104.153.197.0/24",
                    "104.153.199.0/24",
                    "161.36.111.0/24",
                    "162.252.213.0/24",
                    "162.252.214.0/24",
                    "172.98.37.0/24",
                    "172.98.39.0/24",
                    "208.95.112.0/24",
                    "208.95.113.0/24",
                    "208.95.114.0/24",
                    "216.21.12.0/24",
                    "216.21.13.0/24",
                    "216.59.56.0/24",
                    "216.59.57.0/24",
                    "216.59.59.0/24",
                    "216.59.60.0/24",
                    "216.59.63.0/24"
                ],
                "outbound": "direct"
            },
            {
                // "remarks": "direct geoip-ir (Iran IPs)",
                "rule_set": [
                    "geoip-ir",
                    "geoip-private"
                ],
                "outbound": "direct"
            },
            {
                // "remarks": "direct geosite-ir (Iran domains)",
                "rule_set": [
                    "geosite-ir"
                ],
                "outbound": "direct"
            },
            {
                // "remarks": "direct private ip",
                "ip_is_private": true,
                "outbound": "direct"
            },
            {
                "remarks": "reject class D multicast",
                "ip_cidr": [
                    "224.0.0.0/3",
                    "ff00::/8"
                ],
                "action": "reject"
            },
            {
                "remarks": "reject udp on port 443",
                "port": [
                    443
                ],
                "network": "udp",
                "action": "reject"
            },
            {
                "remarks": "reject category-ads-all",
                "rule_set": [
                    "geosite-category-ads-all"
                ],
                "action": "reject"
            }
        ],
        "rule_set": [
            {
                // "download_detour": "direct",
                "tag": "geosite-ir",
                "type": "remote",
                "format": "binary",
                "url": "https://github.com/bootmortis/sing-geosite/releases/latest/download/geosite-all.srs"
            },
            {
                // "download_detour": "direct",
                "tag": "geoip-ir",
