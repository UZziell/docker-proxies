        "rules": [
            {
                "server": "dns-hosts",
                "ip_accept_any": true
            },
            {
                "server": "dns-remote",
                "clash_mode": "Global"
            },
            {
                "server": "dns-local",
                "clash_mode": "Direct"
            },
            {
                "action": "predefined",
                "rcode": "NOTIMP",
                "query_type": [
                    64,
                    65
                ]
            },
            {
                "rule_set": [
                    "geosite-category-ads-all"
                ],
                "action": "predefined",
                "rcode": "NXDOMAIN"
            },
            {
                "server": "dns-local",
                "rule_set": [
                    "geoip-ir"
                ]
            },
            {
                "server": "dns-local",
                "rule_set": [
                    "geosite-ir"
                ]
            },
            {
                "server": "dns-local",
                "domain_suffix": [
                    ".ir"
                ]
            }
        ]
    },
    "route": {
        "default_domain_resolver": {
            "server": "dns-remote",
            "strategy": "ipv4_only",
            "disable_cache": false,
            "rewrite_ttl": null,
            "client_subnet": null
        },
        // "override_android_vpn": true,
        "auto_detect_interface": true,
        "rules": [
            {
                "action": "sniff"
            },
            {
                "protocol": [
                    "dns"
                ],
                "action": "hijack-dns"
            },
            // Clash compatibility
            {
                "outbound": "direct",
                "clash_mode": "Direct"
            },
            {
                "outbound": "proxy",
                "clash_mode": "Global"
            },
            {
                // "remarks": "direct bittorrent",
                "protocol": [
                    "bittorrent"
                ],
                "outbound": "direct"
            },
            {
                // "remarks": "direct custom Iran IP CIDRs",
                "ip_cidr": [
                    "5.160.47.0/24",
                    "5.160.197.0/24",
                    "31.58.239.0/24",
                    "46.38.144.0/24",
